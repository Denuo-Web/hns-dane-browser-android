<string name="wizard_checklist_title">Ścisła lista kontrolna HNS + DANE:</string>
<string name="wizard_checklist_resource">- Zasób HNS ma NS plus użyteczne GLUE4/GLUE6 lub bezpośrednie SYNTH4/SYNTH6.</string>
