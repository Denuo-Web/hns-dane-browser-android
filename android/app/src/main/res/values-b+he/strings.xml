    <string name="trace_fix_hns_stale">תן לסנכרון HNS להתעדכן ואז נסה שוב. ההוכחה המקומית תקפה לגוש ההיסטורי שלה, אך אינה עדכנית מספיק כדי להחליט אם השם קיים כעת.</string>
    <string name="trace_fix_hns_unavailable">סנכרן תחילה כותרות/הוכחות ולאחר מכן נסה שוב. לא הייתה הוכחת HNS מאומתת זמינה.</string>
    <string name="trace_fix_nameserver_unreliable">המועמד שלך לשרת השמות לא ענה בצורה מהימנה. ודא שה-DNS הסמכותי נגיש ב-UDP 53 ו-TCP 53.</string>
    <string name="trace_fix_dnssec_bogus">תקן את שרשרת ה-DNSSEC המואצלת: HNS DS חייב להתאים ל-DNSKEY הבן, החתימות חייבות להיות עדכניות ונתוני ההכחשה חייבים להיות חוקיים.</string>
    <string name="trace_fix_dnssec_before_tlsa">תקן תחילה DNSSEC המואצל. TLSA/DANE לא הוערך מכיוון שפתרון מאובטח נכשל לפני בדיקת ה-TLSA.</string>
    <string name="trace_fix_renew_cert">חדש את אישור ה-HTTPS המקורי. השער הגיע למקור HTTPS, אך TLS נכשל מכיוון שהאישור עבר את חלון התוקף שלו.</string>
    <string name="trace_fix_origin_address_missing">שרת A/AAAA עבור המארח המבוקש מ-DNS מואצל. נתוני HNS GLUE/SYNTH משמשים רק כדי להגיע לשרתי שמות, לא ככתובת המקור.</string>
    <string name="trace_fix_compat_fallback_used">נעשה שימוש ב-DoH fallback של תאימות. הפעל מצב HNS קפדני כדי לוודא אם האתר פועל במלואו ללא DoH של צד שלישי.</string>
    <string name="trace_fix_no_obvious_hns">אין תיקון ברור מהעקיבה הזו. אם HTTPS נכשל, בדוק את TLSA/DANE ברגע שמעקב אחר אישורים מופעל.</string>
    <string name="trace_fix_icann_dnssec_bogus">תקן את שרשרת DNSSEC של ICANN: יש לאמת רשומות DS, DNSKEY, חתימות והכחשה.</string>
    <string name="trace_fix_icann_origin_address_missing">פרסם רשומת A או AAAA מאומתת על ידי DNSSEC עבור המארח הזה.</string>
    <string name="trace_fix_icann_dnssec_before_tlsa">תחילה תקן את ICANN DNSSEC. TLSA/DANE לא הוערך מכיוון שאימות DNS מאובטח נכשל.</string>
    <string name="trace_fix_icann_working">הנתיב של ICANN DNSSEC ו-DANE פועל עבור דף זה.</string>
    <string name="trace_fix_no_obvious_icann">אין תיקון ברור מהעקיבה הזו. בדוק את פרטי TLSA/DANE אם אימות HTTPS נכשל.</string>
